@page
@model InventoryManagementSystem.Pages.StockOut.CreateModel
@{
    ViewData["Title"] = "出庫登録";
}

<div class="page-header">
    <div>
        <h1 class="h3 mb-1">出庫登録</h1>
        <p class="text-muted mb-0">設備修理・定期交換・現場持出などの出庫を記録します。</p>
    </div>
</div>

<div class="card app-card form-card">
    <div class="card-body">
        <form method="post">
            <input type="hidden" asp-for="Transaction.TransactionType" value="@TransactionType.Out" />
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <div class="row g-3">
                <div class="col-12">
                    <label asp-for="Transaction.ProductId" class="form-label"></label>
                    <select asp-for="Transaction.ProductId" asp-items="Model.ProductOptions" class="form-select">
                        <option value="">商品を選択してください</option>
                    </select>
                    <span asp-validation-for="Transaction.ProductId" class="text-danger"></span>
                </div>
                <div class="col-12 col-md-6">
                    <label asp-for="Transaction.Quantity" class="form-label"></label>
                    <input asp-for="Transaction.Quantity" class="form-control" />
                    <span asp-validation-for="Transaction.Quantity" class="text-danger"></span>
                </div>
                <div class="col-12 col-md-6">
                    <label asp-for="Transaction.TransactionDate" class="form-label"></label>
                    <input asp-for="Transaction.TransactionDate" class="form-control" />
                    <span asp-validation-for="Transaction.TransactionDate" class="text-danger"></span>
                </div>
                <div class="col-12">
                    <label asp-for="Transaction.LocationOrPurpose" class="form-label"></label>
                    <input asp-for="Transaction.LocationOrPurpose" class="form-control" placeholder="例: 組立ラインA、成形機3号" />
                    <span asp-validation-for="Transaction.LocationOrPurpose" class="text-danger"></span>
                </div>
                <div class="col-12">
                    <label asp-for="Transaction.Note" class="form-label"></label>
                    <textarea asp-for="Transaction.Note" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="Transaction.Note" class="text-danger"></span>
                </div>
            </div>
            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary">出庫を登録</button>
                <a asp-page="/Inventory/Index" class="btn btn-outline-secondary">戻る</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
