@model Product

<div class="row g-3">
    <div class="col-12 col-md-4">
        <label asp-for="Code" class="form-label"></label>
        <input asp-for="Code" class="form-control" placeholder="例: SEN-001" />
        <span asp-validation-for="Code" class="text-danger"></span>
    </div>
    <div class="col-12 col-md-8">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" placeholder="例: 近接センサー M12" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>
    <div class="col-12 col-md-4">
        <label asp-for="Category" class="form-label"></label>
        <input asp-for="Category" class="form-control" list="categoryOptions" />
        <datalist id="categoryOptions">
            <option value="センサー"></option>
            <option value="PLC部品"></option>
            <option value="電磁弁"></option>
            <option value="シリンダー"></option>
            <option value="ベアリング"></option>
            <option value="ベルト"></option>
            <option value="フィルター"></option>
            <option value="リレー"></option>
            <option value="ヒューズ"></option>
            <option value="油圧ホース"></option>
            <option value="工具"></option>
        </datalist>
        <span asp-validation-for="Category" class="text-danger"></span>
    </div>
    <div class="col-6 col-md-4">
        <label asp-for="Unit" class="form-label"></label>
        <input asp-for="Unit" class="form-control" />
        <span asp-validation-for="Unit" class="text-danger"></span>
    </div>
    <div class="col-6 col-md-4">
        <label asp-for="SafetyStock" class="form-label"></label>
        <input asp-for="SafetyStock" class="form-control" />
        <span asp-validation-for="SafetyStock" class="text-danger"></span>
    </div>
    <div class="col-12">
        <label asp-for="Description" class="form-label"></label>
        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>
</div>
