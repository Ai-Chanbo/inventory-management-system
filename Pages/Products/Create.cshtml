@page
@model InventoryManagementSystem.Pages.Products.CreateModel
@{
    ViewData["Title"] = "商品登録";
}

<div class="page-header">
    <div>
        <h1 class="h3 mb-1">商品登録</h1>
        <p class="text-muted mb-0">在庫管理対象の商品を追加します。</p>
    </div>
</div>

<div class="card app-card form-card">
    <div class="card-body">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <partial name="_ProductForm" model="Model.Product" />
            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary">登録</button>
                <a asp-page="Index" class="btn btn-outline-secondary">戻る</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
