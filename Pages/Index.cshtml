@page
@model IndexModel
@{
    ViewData["Title"] = "ダッシュボード";
}

<div class="page-header">
    <div>
        <p class="text-uppercase text-primary fw-semibold small mb-1">Manufacturing Inventory Dashboard</p>
        <h1 class="h3 mb-1">ダッシュボード</h1>
        <p class="text-muted mb-0">製造現場の保全部品・消耗品在庫を可視化します。</p>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-primary" asp-page="/StockIn/Create">入庫登録</a>
        <a class="btn btn-outline-primary" asp-page="/StockOut/Create">出庫登録</a>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-12 col-md-6 col-xl-3">
        <div class="metric-card border-start border-primary border-4">
            <span>登録品目</span>
            <strong>@Model.Dashboard.ProductCount</strong>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-3">
        <div class="metric-card border-start border-success border-4">
            <span>総在庫数</span>
            <strong>@Model.Dashboard.TotalStock</strong>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-3">
        <div class="metric-card border-start border-warning border-4">
            <span>注意在庫</span>
            <strong>@Model.Dashboard.LowStockCount</strong>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-3">
        <div class="metric-card border-start border-danger border-4">
            <span>不足在庫</span>
            <strong>@Model.Dashboard.OutOfStockCount</strong>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-12 col-xl-7">
        <div class="card app-card h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h2 class="h5 mb-0">カテゴリ別在庫</h2>
                    <span class="badge text-bg-light">Chart.js</span>
                </div>
                <div class="chart-wrap">
                    <canvas id="categoryStockChart"></canvas>
                </div>
            </div>
        </div>
    </div>
    <div class="col-12 col-xl-5">
        <div class="card app-card h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h2 class="h5 mb-0">在庫不足アラート</h2>
                    <a asp-page="/Alerts/Index" class="btn btn-sm btn-outline-danger">一覧</a>
                </div>
                @if (!Model.Dashboard.LowStocks.Any())
                {
                    <div class="empty-state">安全在庫を下回る品目はありません。</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table align-middle">
                            <thead>
                                <tr>
                                    <th>商品</th>
                                    <th class="text-end">現在庫</th>
                                    <th>状態</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.Dashboard.LowStocks)
                                {
                                    <tr>
                                        <td>
                                            <div class="fw-semibold">@item.ProductName</div>
                                            <div class="text-muted small">@item.ProductCode / @item.Category</div>
                                        </td>
                                        <td class="text-end">@item.CurrentStock @item.Unit</td>
                                        <td><span class="badge @item.StatusBadgeClass">@item.StatusText</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="col-12">
        <div class="card app-card">
            <div class="card-body">
                <h2 class="h5 mb-3">最近の入出庫</h2>
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead>
                            <tr>
                                <th>日付</th>
                                <th>区分</th>
                                <th>商品</th>
                                <th class="text-end">数量</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Dashboard.RecentTransactions)
                            {
                                <tr>
                                    <td>@item.TransactionDate.ToString("yyyy/MM/dd")</td>
                                    <td>
                                        <span class="badge @(item.TypeText == "入庫" ? "text-bg-primary" : "text-bg-secondary")">@item.TypeText</span>
                                    </td>
                                    <td>
                                        <div class="fw-semibold">@item.ProductName</div>
                                        <div class="text-muted small">@item.ProductCode</div>
                                    </td>
                                    <td class="text-end">@item.Quantity @item.Unit</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        window.categoryStockData = {
            labels: @Html.Raw(Json.Serialize(Model.Dashboard.CategoryStocks.Select(x => x.Category))),
            values: @Html.Raw(Json.Serialize(Model.Dashboard.CategoryStocks.Select(x => x.Quantity)))
        };
    </script>
    <script src="~/js/dashboard.js" asp-append-version="true"></script>
}
