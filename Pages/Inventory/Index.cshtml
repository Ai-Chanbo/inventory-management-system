@page
@model InventoryManagementSystem.Pages.Inventory.IndexModel
@{
    ViewData["Title"] = "在庫一覧";
}

<div class="page-header">
    <div>
        <h1 class="h3 mb-1">在庫一覧</h1>
        <p class="text-muted mb-0">入出庫履歴から現在庫を自動計算しています。</p>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-primary" asp-page="/StockIn/Create">入庫登録</a>
        <a class="btn btn-outline-primary" asp-page="/StockOut/Create">出庫登録</a>
    </div>
</div>

<div class="card app-card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>商品コード</th>
                        <th>商品名</th>
                        <th>カテゴリ</th>
                        <th class="text-end">現在庫</th>
                        <th class="text-end">安全在庫</th>
                        <th>状態</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td class="fw-semibold">@item.ProductCode</td>
                            <td><a asp-page="/Products/Details" asp-route-id="@item.ProductId">@item.ProductName</a></td>
                            <td><span class="badge category-badge">@item.Category</span></td>
                            <td class="text-end">@item.CurrentStock @item.Unit</td>
                            <td class="text-end">@item.SafetyStock @item.Unit</td>
                            <td><span class="badge @item.StatusBadgeClass">@item.StatusText</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
